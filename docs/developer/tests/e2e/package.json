{
  "name": "cognitive-fabric-visualizer-e2e",
  "version": "1.0.0",
  "description": "Comprehensive E2E testing framework for Cognitive Fabric Visualizer",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:performance": "playwright test tests/e2e/performance/",
    "test:mobile": "playwright test tests/e2e/mobile/",
    "test:visual": "playwright test tests/e2e/visual/",
    "test:workflows": "playwright test tests/e2e/workflows/",
    "test:setup": "playwright test tests/e2e/setup/",
    "test:chrome": "playwright test --project=chromium-desktop",
    "test:firefox": "playwright test --project=firefox-desktop",
    "test:webkit": "playwright test --project=webkit-desktop",
    "test:mobile-chrome": "playwright test --project=mobile-chrome",
    "test:mobile-safari": "playwright test --project=mobile-safari",
    "test:ci": "playwright test --reporter=html,/json,junit --output-dir=test-results",
    "test:performance-ci": "playwright test tests/e2e/performance/ --reporter=tests/e2e/helpers/performance-reporter.ts",
    "report": "playwright show-report",
    "report:performance": "node -e \"console.log(JSON.stringify(require('./test-results/performance/summary-report.json'), null, 2))\"",
    "lint:tests": "eslint tests/e2e --ext .ts,.js",
    "typecheck:tests": "tsc --noEmit tests/e2e/**/*.ts",
    "validate:fixtures": "node -e \"console.log('✅ Fixtures validated:', Object.keys(require('./tests/e2e/fixtures/cognitive-graph-data.ts')).length)\"",
    "clean:results": "rimraf test-results playwright-report .playwright",
    "update:snapshots": "playwright test --update-snapshots",
    "install:browsers": "playwright install",
    "install:deps": "npm install && npm run install:browsers"
  },
  "keywords": [
    "e2e-testing",
    "playwright",
    "cognitive-visualization",
    "3d-graphics",
    "performance-testing",
    "mobile-testing",
    "visual-regression"
  ],
  "author": "Cognitive Fabric Visualizer Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.8.0",
    "eslint": "^8.54.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "playwright": {
    "testMatch": [
      "tests/e2e/**/*.spec.ts"
    ],
    "testIgnore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**"
    ]
  }
}