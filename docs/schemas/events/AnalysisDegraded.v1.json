{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/AnalysisDegraded.v1.json",
  "title": "AnalysisDegraded event payload v1",
  "description": "Emitted when an Analysis continues with reduced capability (e.g. a dropped Ensemble member). Carries an array of what was dropped.",
  "type": "object",
  "required": ["analysisId", "reason", "dropped"],
  "additionalProperties": false,
  "properties": {
    "analysisId": { "$ref": "#/$defs/Ulid" },
    "reason": { "type": "string", "minLength": 1 },
    "dropped": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
