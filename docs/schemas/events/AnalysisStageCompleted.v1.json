{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/AnalysisStageCompleted.v1.json",
  "title": "AnalysisStageCompleted event payload v1",
  "type": "object",
  "required": ["analysisId", "stage", "durationMs"],
  "additionalProperties": false,
  "properties": {
    "analysisId": { "$ref": "#/$defs/Ulid" },
    "stage": {
      "enum": ["SEGMENT", "DECOMPOSE", "FUSE", "SYMBOLIC", "GRAPH_UPDATE", "THREAD_PREDICT", "NOTIFY"]
    },
    "durationMs": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
