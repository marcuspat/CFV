{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/MediaPurged.v1.json",
  "title": "MediaPurged event payload v1",
  "type": "object",
  "required": ["uploadId", "policy"],
  "additionalProperties": false,
  "properties": {
    "uploadId": { "$ref": "#/$defs/Ulid" },
    "policy": { "enum": ["DEFAULT", "USER_REQUEST"] }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
