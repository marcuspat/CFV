{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/ConversationDeleted.v1.json",
  "title": "ConversationDeleted event payload v1",
  "type": "object",
  "required": ["conversationId", "reason"],
  "additionalProperties": false,
  "properties": {
    "conversationId": { "$ref": "#/$defs/Ulid" },
    "reason": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
