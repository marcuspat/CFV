{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/CognitiveElementDetected.v1.json",
  "title": "CognitiveElementDetected event payload v1",
  "type": "object",
  "required": [
    "analysisId",
    "cognitiveElementId",
    "dimension",
    "span",
    "confidence",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "analysisId": { "$ref": "#/$defs/Ulid" },
    "cognitiveElementId": { "$ref": "#/$defs/Ulid" },
    "dimension": {
      "enum": [
        "FACTUAL_RETRIEVAL",
        "LOGICAL_INFERENCE",
        "CREATIVE_SYNTHESIS",
        "META_COGNITION"
      ]
    },
    "span": {
      "type": "object",
      "required": ["turnId", "startOffset", "endOffset"],
      "additionalProperties": false,
      "properties": {
        "turnId": { "$ref": "#/$defs/Ulid" },
        "startOffset": { "type": "integer", "minimum": 0 },
        "endOffset": { "type": "integer", "minimum": 0 }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["span", "verbatim"],
        "additionalProperties": false,
        "properties": {
          "span": { "$ref": "#/properties/span" },
          "verbatim": { "type": "string" },
          "externalCitations": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
