{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/UserDisabled.v1.json",
  "title": "UserDisabled event payload v1",
  "type": "object",
  "required": ["userId", "tenantId", "reason"],
  "additionalProperties": false,
  "properties": {
    "userId": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenantId": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "reason": { "type": "string", "minLength": 1 }
  }
}
