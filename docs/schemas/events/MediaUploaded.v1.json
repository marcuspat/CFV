{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/MediaUploaded.v1.json",
  "title": "MediaUploaded event payload v1",
  "type": "object",
  "required": ["uploadId", "tenantId", "mimeType", "byteSize"],
  "additionalProperties": false,
  "properties": {
    "uploadId": { "$ref": "#/$defs/Ulid" },
    "tenantId": { "$ref": "#/$defs/Ulid" },
    "mimeType": { "type": "string", "minLength": 1 },
    "byteSize": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
