{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/UserRegistered.v1.json",
  "title": "UserRegistered event payload v1",
  "description": "Emitted by the Identity & Access context when a new user is provisioned.",
  "type": "object",
  "required": ["userId", "tenantId", "email", "roles"],
  "additionalProperties": false,
  "properties": {
    "userId": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenantId": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "email": { "type": "string", "format": "email" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["viewer", "analyst", "admin", "developer", "service"]
      }
    }
  }
}
