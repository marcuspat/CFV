{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfv.dev/schemas/events/MediaProcessed.v1.json",
  "title": "MediaProcessed event payload v1",
  "type": "object",
  "required": ["uploadId", "conversationId", "durationMs"],
  "additionalProperties": false,
  "properties": {
    "uploadId": { "$ref": "#/$defs/Ulid" },
    "conversationId": { "$ref": "#/$defs/Ulid" },
    "durationMs": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "Ulid": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
  }
}
