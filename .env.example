# ============================================================
# Cognitive Fabric Visualizer — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to source control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3001

# --- Frontend (client) ---
# Base URL the React app uses for API calls. Leave empty to issue requests
# relative to the current origin (and proxy them in dev/prod). For a standalone
# dev backend, set this to the full API base, e.g. http://localhost:3001/api
REACT_APP_API_URL=http://localhost:3001/api

# --- AI Providers (at least one required for real analysis) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# AI model selection (optional overrides)
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- PostgreSQL ---
# Preferred in production (takes precedence over the discrete DB_* fields below):
DATABASE_URL=postgres://postgres:changeme@localhost:5432/cognitive_fabric
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cognitive_fabric
DB_USER=postgres
DB_PASSWORD=changeme

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m

# --- Cognitive processing ---
VERIFICATION_THRESHOLD=0.95
MAX_CONCURRENT_CONNECTIONS=100
COGNITIVE_PROCESSING_TIMEOUT=30000
WEBSOCKET_HEARTBEAT=30000

# --- Monitoring ---
MONITORING_ENABLED=true
MONITORING_INTERVAL=5000

# --- Logging ---
# pino log level: error | warn | info | debug
LOG_LEVEL=info

# --- CORS ---
# Comma-separated explicit allowlist of permitted browser origins (no wildcards).
CORS_ORIGINS=http://localhost:3000
