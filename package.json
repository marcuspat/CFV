{
  "name": "cfv",
  "version": "1.0.0",
  "description": "The \"Cognitive Fabric\" Visualizer",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:performance": "jest --testPathPattern=performance",
    "test:ml": "jest --testPathPattern=ml",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --watchAll=false && playwright test",
    "test:accuracy": "jest --testPathPattern=ml --testNamePattern='accuracy'",
    "test:load": "artillery run tests/performance/scenarios/load-test-config.yml",
    "test:database": "tsx tests/database/validation-test-suite.ts",
    "test:database:validate": "tsx tests/database/validation-test-suite.ts",
    "test:performance:comprehensive": "tsx tests/performance/run-performance-tests.ts",
    "test:performance:load": "tsx tests/performance/run-performance-tests.ts --skip-stress --skip-memory --skip-database --skip-artillery",
    "test:performance:stress": "tsx tests/performance/run-performance-tests.ts --skip-load --skip-memory --skip-database --skip-artillery",
    "test:performance:database": "tsx tests/performance/run-performance-tests.ts --skip-load --skip-stress --skip-memory --skip-artillery",
    "test:performance:memory": "tsx tests/performance/run-performance-tests.ts --skip-load --skip-stress --skip-database --skip-artillery",
    "test:performance:artillery": "tsx tests/performance/run-performance-tests.ts --skip-load --skip-stress --skip-memory --skip-database",
    "test:performance:all": "tsx tests/performance/run-performance-tests.ts",
    "test:error": "node scripts/run-error-tests.js",
    "test:error-handling": "jest tests/error-handling --verbose",
    "test:chaos": "jest tests/chaos-engineering --testTimeout=300000 --verbose",
    "test:validation": "jest tests/error-handling/comprehensive-error-tests.ts --testNamePattern='Input Validation'",
    "test:resilience": "npm run test:chaos && npm run test:error-handling",
    "test:integration:api": "jest --config jest.config.integration.cjs",
    "build": "tsc",
    "lint": "echo 'Add linting here'",
    "lint:fix": "eslint src tests --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "playwright": "playwright test",
    "playwright:install": "playwright install",
    "validate:config": "tsx scripts/validate-config.ts",
    "validate:all": "./scripts/test-all-configs.sh",
    "validate:deps": "npm audit --audit-level=moderate",
    "validate:security": "npm audit --audit-level=high",
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "cd src/client && npm run dev",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:client\" \"echo 'Starting ML API service...'\"",
    "start": "node dist/server/index.js",
    "docker:build": "docker build -t cognitive-fabric .",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcuspat/CFV.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/marcuspat/CFV/issues"
  },
  "homepage": "https://github.com/marcuspat/CFV#readme",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^24.9.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@types/three": "^0.184.1",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "artillery": "^2.0.26",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-react-app": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "newman": "^6.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "d3": "^7.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.15.0",
    "openai": "^4.67.3",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.6.12",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.158.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  }
}
